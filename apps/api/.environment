# Sourced automatically by Upsun at runtime (and in the deploy hook).
# Builds the URLs the app expects from the service environment variables
# generated by the `postgresql` and `redis` relationships.
export DATABASE_URL="postgresql://${POSTGRESQL_USERNAME}:${POSTGRESQL_PASSWORD}@${POSTGRESQL_HOST}:${POSTGRESQL_PORT}/${POSTGRESQL_PATH}"
export REDIS_URL="redis://${REDIS_HOST}:${REDIS_PORT}"
