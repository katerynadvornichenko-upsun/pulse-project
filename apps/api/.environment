# Sourced automatically by Upsun at runtime (and in the deploy hook).
# Builds the URLs the app expects from the service environment variables
# generated by the relationships in .upsun/config.yaml.
export DATABASE_URL="postgresql://${POSTGRESQL_USERNAME}:${POSTGRESQL_PASSWORD}@${POSTGRESQL_HOST}:${POSTGRESQL_PORT}/${POSTGRESQL_PATH}"

# Only set when the postgresql-replica relationship exists (currently
# disabled in .upsun/config.yaml; see the note there). The guard prevents
# exporting a garbage URL built from empty variables — when unset, the app
# falls back to the primary for reads.
if [ -n "${POSTGRESQL_REPLICA_HOST}" ]; then
    export DATABASE_REPLICA_URL="postgresql://${POSTGRESQL_REPLICA_USERNAME}:${POSTGRESQL_REPLICA_PASSWORD}@${POSTGRESQL_REPLICA_HOST}:${POSTGRESQL_REPLICA_PORT}/${POSTGRESQL_REPLICA_PATH}"
fi

export REDIS_URL="redis://${REDIS_HOST}:${REDIS_PORT}"
